# True Love AI Configuration Example
# ============================================

# ==================== 服务基础配置 ====================

base_server:
  host: "http://localhost:5000"
  self_wxid: ""
  master_wxid: ""
  master_group: ""

http:
  host: "0.0.0.0"
  port: 8088
  token: ["your_token"]

session:
  ttl_seconds: 86400        # 会话过期时间（秒），默认 24 小时
  compress_threshold: 50    # 历史消息超过此条数时触发压缩
  compress_keep_recent: 10  # 压缩时保留最近 N 条完整消息

# ==================== LLM 配置 ====================

llm:
  # 默认系统提示词（兜底，未配置 user_prompt_map 的用户均使用此提示词）
  system_prompt: "你是一个可爱的智能助手~"
  vision_prompt: "你是一个专业的图像分析助手"

  # 命名 prompt 集合（可定义多个，供 user_prompt_map 引用）
  # prompts:
  #   academic: "你是一个学术助手..."
  #   formal: "你是一个正式的助手..."

  # 用户/群 → prompt 名映射（未配置则走 system_prompt）
  # user_prompt_map:
  #   wxid_xxxxxx: academic
  #   room@chatroom: formal

  # 模型配置（完整 LiteLLM 字符串，直接写前缀，不做自动转换）
  # 单一模型直接写字符串；image/video 支持 default + fallback 自动降级
  chat:
    default: "openai/gpt-5.4"
  compress:
    default: "openai/gpt-5.4-nano"
  vision:
    default: "openai/gpt-5.4"
  image:
    default:  "openai/gpt-image-1"
    fallback: "openai/gemini/imagen-4.0-generate-001"
  # video:
  #   default:  "openai/sora-2-pro"          # Sora 直连，使用 platform_key.openai_key
  #   fallback: "gemini/veo-3.1-generate-preview"  # Veo 直连，使用 platform_key.gemini_key

# ==================== 第三方平台 Key ====================

platform_key:
  litellm_api_key: ""           # LiteLLM 代理 API key（聊天/图像通用）
  litellm_base_url: ""          # LiteLLM 代理地址
  openai_key: ""                # OpenAI 直连 key（Sora 视频生成专用）
  gemini_key: ""                # Gemini 直连 key（Veo 视频生成专用）

# ==================== 外部服务配置 ====================

nexu:
  base_url: "http://localhost:3010"
  token: ""

muninn:
  api_base_url: ""
  admin_token: ""

github:
  token: "ghp_xxx"

# ==================== Skill 权限配置 ====================
# 查找顺序：skill 名 → default → 未配置则所有人可用

skill_permissions:
  default: ["管理员昵称"]
  list_models: ["管理员昵称"]
  set_model: ["管理员昵称"]
  run_job: ["管理员昵称"]
  deploy: ["管理员昵称"]
  reload_config: ["管理员昵称"]
  listen_manage: ["管理员昵称"]
  muninn_cdk: ["管理员昵称"]
