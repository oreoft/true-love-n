# ── Server ────────────────────────────────────────────
# PORT=3010
# HOST=127.0.0.1

# ── OpenClaw ──────────────────────────────────────────
# OPENCLAW_STATE_DIR=~/.openclaw
# OPENCLAW_GATEWAY_PORT=18789
# OPENCLAW_BIN=openclaw

# ── Runtime ───────────────────────────────────────────
