# RUNTIME_MANAGE_OPENCLAW_PROCESS=true
# RUNTIME_GATEWAY_PROBE_ENABLED=true


# ── Model ─────────────────────────────────────────────
# DEFAULT_MODEL_ID=anthropic/claude-sonnet-4
